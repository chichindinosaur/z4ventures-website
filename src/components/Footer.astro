      <div class="footer-col">
        <h4>Quick Links</h4>
        <a href="/">Home</a>
        <a href="/products">Products</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="footer-col">
        <h4>Products</h4>
        <a href="/products">Deep Well Drilling</a>
        <a href="/products">Valves & Pipeline</a>
