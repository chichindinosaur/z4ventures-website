---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <span class="logo-z">Z</span><span class="logo-4">4</span><span class="logo-ventures"> Ventures</span>
      <p>Trusted supplier of construction and drilling consumables.</p>
    </div>
    <div class="footer-links">
      <h4>Quick Links</h4>
      <a href="/">Home</a>
      <a href="/products">Products</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="footer-contact">
      <h4>Contact</h4>
      <p>0921 863 4645</p>
      <p>inquiry.z4trading@gmail.com</p>
      <p>Meycauayan, Bulacan</p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Z4 Ventures. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: #d1d5db;
    padding-top: 3rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .footer-brand .logo-z {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .footer-brand .logo-4 {
    color: var(--color-accent);
    font-size: 1.5rem;
    font-weight: 800;
  }

  .footer-brand .logo-ventures {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .footer-brand p {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .footer-links,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer h4 {
    color: #fff;
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .footer-links a {
    color: #d1d5db;
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-contact p {
    font-size: 0.9rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 0;
    font-size: 0.85rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
