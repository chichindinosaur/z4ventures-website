---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About" description="Z4 Ventures Inc. — trusted supplier of construction and drilling consumables across the Philippines.">
  <section class="page-header">
    <div class="container">
      <h1>About Z4 Ventures</h1>
      <p>Your trusted partner in building better projects nationwide.</p>
    </div>
  </section>

  <section class="section">
    <div class="container about-content">
      <div class="about-text">
        <h2>Who We Are</h2>
        <p><strong>Z4 Trading supplies high-quality construction and drilling consumables</strong>, from pipes, screens, valves, submersible cables, and more, for projects across the Philippines.</p>
        <p><strong>We serve contractors, developers, and government agencies</strong>, ensuring strict standards of durability and safety.</p>
        <p>We bridge <strong>quality and affordability</strong> through strong manufacturer partnerships and a <strong>customer-focused approach</strong>, delivering the right solutions on time and at competitive prices.</p>
        <p>Driven by <strong>integrity and innovation</strong>, Z4 Trading is your trusted partner in building better projects nationwide.</p>
      </div>
    </div>
  </section>

  <section class="section vision-mission">
    <div class="container">
      <div class="vm-grid">
        <div class="vm-card">
          <h2>Our Vision</h2>
          <p><strong>Z4 is the trusted partner in construction and industrial supply, known for quality, innovation, and integrity.</strong></p>
          <p>We aim to help build sustainable communities and modern infrastructure across the Philippines through dependable solutions and strong partnerships.</p>
        </div>
        <div class="vm-card">
          <h2>Our Mission</h2>
          <ul>
            <li>Provide innovative, reliable, and cost-effective solutions with timely delivery and exceptional service</li>
            <li>Deliver quality products that create lasting value and build trust through integrity and customer focus</li>
            <li>Foster long-term partnerships that drive industry growth and sustainable progress</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section clients-section">
    <div class="container">
      <h2 class="section-title">Trusted By</h2>
      <p class="section-subtitle">Leading companies across construction, water utilities, and real estate rely on Z4.</p>
      <div class="clients-grid">
        <div class="client-name">Manila Water</div>
        <div class="client-name">Maynilad</div>
        <div class="client-name">PrimeWater</div>
        <div class="client-name">AyalaLand</div>
        <div class="client-name">SMDC</div>
        <div class="client-name">Megawide</div>
        <div class="client-name">D.M. Consunji, Inc.</div>
        <div class="client-name">MDC</div>
        <div class="client-name">NGCP</div>
        <div class="client-name">CG Integra Corporation</div>
        <div class="client-name">Sinian Int'l Corporation</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Want to Partner With Us?</h2>
      <p class="section-subtitle">We're always looking for new partners to grow with.</p>
      <a href="/contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f172a 100%);
    color: #fff;
    padding: 4rem 0;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.1rem;
    color: #cbd5e1;
    max-width: 550px;
  }

  .about-text {
    max-width: 700px;
  }

  .about-text h2 {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .about-text p {
    color: var(--color-text-light);
    font-size: 1.05rem;
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .vision-mission {
    background: var(--color-bg-alt);
  }

  .vm-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .vm-card {
    padding: 2rem;
    background: var(--color-bg);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .vm-card h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .vm-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .vm-card ul {
    padding-left: 1.25rem;
    list-style: none;
  }

  .vm-card ul li {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .vm-card ul li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .clients-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .client-name {
    padding: 0.6rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .vm-grid {
      grid-template-columns: 1fr;
    }

    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>
