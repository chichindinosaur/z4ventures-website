---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Quality Products,<br />Trusted Partner</h1>
      <p>Z4 Ventures supplies high-quality construction and drilling consumables — pipes, screens, valves, STPs, and more — for projects across the Philippines.</p>
      <div class="hero-actions">
        <a href="/products" class="btn btn-primary">View Products</a>
        <a href="/contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Core Products -->
  <section class="section products-overview">
    <div class="container">
      <h2 class="section-title">Core Products</h2>
      <p class="section-subtitle">Trusted supplier of water infrastructure and drilling products.</p>
      <div class="segments">
        <a href="/products" class="segment-card">
          <div class="segment-image segment-terra">
            <span class="segment-badge">Terra</span>
          </div>
          <h3>Deep Well Drilling</h3>
          <span class="segment-link">View Products</span>
        </a>
        <a href="/products" class="segment-card">
          <div class="segment-image segment-azul">
            <span class="segment-badge">Azul</span>
          </div>
          <h3>Valves & Pipeline</h3>
          <span class="segment-link">View Products</span>
        </a>
        <a href="/products" class="segment-card">
          <div class="segment-image segment-pvc">
          </div>
          <h3>PVC Pipes & Fittings</h3>
          <span class="segment-link">View Products</span>
        </a>
        <a href="/products" class="segment-card">
          <div class="segment-image segment-enviro">
            <span class="segment-badge">Enviro</span>
          </div>
          <h3>Sewage Treatment Plants</h3>
          <span class="segment-link">View Products</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container cta-content">
      <h2>Ready to Build Together?</h2>
      <p>Whether you need drilling products, valves, pipes, or sewage treatment systems — we deliver on time at competitive prices.</p>
      <a href="/contact" class="btn btn-primary">Contact Us</a>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f172a 100%);
    color: #fff;
    padding: 6rem 0;
  }

  .hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: #cbd5e1;
    max-width: 550px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .segments {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .segment-card {
    text-align: center;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .segment-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-3px);
  }

  .segment-image {
    height: 200px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 0.75rem;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .segment-enviro {
    background: linear-gradient(135deg, #0d9488 0%, #065f46 100%);
  }

  .segment-terra {
    background: linear-gradient(135deg, #78716c 0%, #44403c 100%);
  }

  .segment-azul {
    background: linear-gradient(135deg, #2563eb 0%, #1e3a5f 100%);
  }

  .segment-pvc {
    background: linear-gradient(135deg, #ea580c 0%, #9a3412 100%);
  }

  .segment-badge {
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .segment-card h3 {
    font-size: 1.15rem;
    color: var(--color-primary);
    padding: 1rem 1rem 0.25rem;
  }

  .segment-link {
    display: inline-block;
    padding: 0.5rem 1rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cta {
    background: var(--color-bg-alt);
    text-align: center;
  }

  .cta h2 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.25rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .segments {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
