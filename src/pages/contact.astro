---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact" description="Get in touch with Z4 Ventures for construction and drilling product inquiries.">
  <!-- Page Header -->
  <section class="page-header">
    <div class="page-header-bg">
      <div class="page-header-gradient"></div>
      <div class="page-header-grid"></div>
    </div>
    <div class="container page-header-content">
      <span class="section-label" style="color: rgba(255,255,255,0.6);">Contact Us</span>
      <h1>Let's Build Together</h1>
      <p>Have a project in mind? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <!-- Form -->
      <div class="contact-form animate-on-scroll">
        <h2>Send Us a Message</h2>
        <div class="selected-products" id="selected-products" style="display:none;">
          <h3>Products you're inquiring about:</h3>
          <div class="product-tags" id="product-tags"></div>
        </div>
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="77cf65a1-8678-48e5-a292-453b683a76e8" />
          <input type="hidden" name="subject" id="form-subject" value="New inquiry from Z4 Ventures website" />
          <input type="hidden" name="from_name" value="Z4 Ventures Website" />
          <input type="hidden" name="redirect" value="https://z4ventures.com/contact?success=true" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="inquiry_type">Subject</label>
            <select id="inquiry_type" name="inquiry_type">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Product Inquiry">Product Inquiry</option>
              <option value="Partnership Opportunity">Partnership Opportunity</option>
              <option value="Request a Quote">Request a Quote</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            Send Message
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
        <div class="form-success" id="form-success" style="display:none;">
          <div class="success-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Message Sent!</h3>
          <p>Thank you for reaching out. We'll get back to you shortly.</p>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="contact-sidebar animate-on-scroll">
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <h4>Phone</h4>
            <p>0921 863 4645</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h4>Email</h4>
            <p>inquiry.z4trading@gmail.com</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h4>Address</h4>
            <p>Tempo, Bagbaguin rd., Brgy. Bagbaguin, Meycauayan, Bulacan</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <div>
            <h4>Business Hours</h4>
            <p>Monday - Sunday<br />9:00 AM - 6:00 PM</p>
          </div>
        </div>

        <div class="viber-cta">
          <p>Prefer to chat?</p>
          <a href="https://connect.viber.com/business/a0ddd5f0-a31b-11f0-88cf-5231f1c5f3a1" target="_blank" rel="noopener" class="btn-viber">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M11.4 0C9.473.028 5.333.344 3.02 2.467 1.302 4.187.6 6.7.52 9.817c-.08 3.12-.18 8.973 5.48 10.56h.004l-.004 2.416s-.036.977.608 1.176c.776.24 1.232-.5 1.972-1.296.408-.436.968-1.076 1.392-1.564 3.836.324 6.784-.416 7.12-.528.776-.256 5.164-.816 5.876-6.656.736-6.016-.356-9.812-2.292-11.52l.004-.004c-.536-.488-2.66-2.016-7.592-2.212 0 0-.376-.02-.888-.016z"/></svg>
            Message us on Viber
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Page Header */
  .page-header {
    position: relative;
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    overflow: hidden;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
  }

  .page-header-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  }

  .page-header-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .page-header-content {
    position: relative;
    z-index: 1;
    color: #fff;
  }

  .page-header-content .section-label::before {
    background: rgba(255, 255, 255, 0.3);
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.1rem;
    color: #94a3b8;
    max-width: 550px;
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-fast);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(232, 83, 30, 0.1);
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  /* Selected products */
  .selected-products {
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .selected-products h3 {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Success */
  .form-success {
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(16, 185, 129, 0.06);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-md);
  }

  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .form-success h3 {
    color: #059669;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .form-success p {
    color: var(--color-text-secondary);
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .info-card:hover {
    border-color: var(--color-accent);
  }

  .info-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--color-accent-light);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-card h4 {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
  }

  .info-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Viber */
  .viber-cta {
    margin-top: 0.5rem;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .viber-cta p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .btn-viber {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #7360F2;
    color: #fff;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all var(--transition-fast);
    cursor: pointer;
    width: 100%;
  }

  .btn-viber:hover {
    background: #5b48d4;
    color: #fff;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);

  // Show success message after form submission
  if (params.get('success') === 'true') {
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');
    if (form && success) {
      form.style.display = 'none';
      success.style.display = 'block';
    }
  }

  // Pre-fill form with selected products from products page
  const productsParam = params.get('products');
  if (productsParam) {
    const products = decodeURIComponent(productsParam).split(',').filter(Boolean);

    if (products.length > 0) {
      const container = document.getElementById('selected-products');
      const tagsEl = document.getElementById('product-tags');
      const inquiryType = document.getElementById('inquiry_type') as HTMLSelectElement;
      const formSubject = document.getElementById('form-subject') as HTMLInputElement;
      const message = document.getElementById('message') as HTMLTextAreaElement;

      if (container) container.style.display = 'block';
      products.forEach(name => {
        const tag = document.createElement('span');
        tag.className = 'product-tag';
        tag.textContent = name;
        tagsEl?.appendChild(tag);
      });

      if (inquiryType) inquiryType.value = 'Product Inquiry';
      if (formSubject) formSubject.value = `Product Inquiry: ${products.join(', ')}`;
      if (message) message.value = `Hi, I'm interested in the following products: ${products.join(', ')}.\n\nPlease provide more information about pricing and availability.`;
    }
  }
</script>
