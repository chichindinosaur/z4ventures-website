---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact" description="Get in touch with Z4 Ventures for trading inquiries and partnerships.">
  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Have a question or want to discuss a partnership? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-form">
        <h2>Send Us a Message</h2>
        <div class="selected-products" id="selected-products" style="display:none;">
          <h3>Products you're inquiring about:</h3>
          <div class="product-tags" id="product-tags"></div>
        </div>
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="77cf65a1-8678-48e5-a292-453b683a76e8" />
          <input type="hidden" name="subject" id="form-subject" value="New inquiry from Z4 Ventures website" />
          <input type="hidden" name="from_name" value="Z4 Ventures Website" />
          <input type="hidden" name="redirect" value="https://z4ventures.com/contact?success=true" />
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="inquiry_type">Subject</label>
            <select id="inquiry_type" name="inquiry_type">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Product Inquiry">Product Inquiry</option>
              <option value="Partnership Opportunity">Partnership Opportunity</option>
              <option value="Request a Quote">Request a Quote</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
        <div class="form-success" id="form-success" style="display:none;">
          <h3>Message Sent!</h3>
          <p>Thank you for reaching out. We'll get back to you shortly.</p>
        </div>
      </div>
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <div class="info-item">
          <h3>Phone</h3>
          <p>0921 863 4645</p>
        </div>
        <div class="info-item">
          <h3>Email</h3>
          <p>inquiry.z4trading@gmail.com</p>
        </div>
        <div class="info-item">
          <h3>Address</h3>
          <p>Tempo, Bagbaguin rd., Brgy. Bagbaguin,<br />Meycauayan, Bulacan</p>
        </div>
        <div class="info-item">
          <h3>Business Hours</h3>
          <p>Monday - Sunday<br />9:00 AM - 6:00 PM</p>
        </div>
        <div class="viber-cta">
          <p>Prefer to chat?</p>
          <a href="https://connect.viber.com/business/a0ddd5f0-a31b-11f0-88cf-5231f1c5f3a1" target="_blank" rel="noopener" class="btn-viber">
            Message us on Viber
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f172a 100%);
    color: #fff;
    padding: 4rem 0;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.1rem;
    color: #cbd5e1;
    max-width: 550px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  .contact-form h2,
  .contact-info h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .info-item {
    margin-bottom: 1.5rem;
  }

  .info-item h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .info-item p {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .selected-products {
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: rgba(37, 99, 235, 0.06);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: 8px;
  }

  .selected-products h3 {
    font-size: 0.9rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-tag {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .form-success {
    text-align: center;
    padding: 2rem;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 8px;
  }

  .form-success h3 {
    color: #059669;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .form-success p {
    color: var(--color-text-light);
  }

  .viber-cta {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .viber-cta p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .btn-viber {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: #7360F2;
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-viber:hover {
    background: #5b48d4;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);

  // Show success message after form submission
  if (params.get('success') === 'true') {
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');
    if (form && success) {
      form.style.display = 'none';
      success.style.display = 'block';
    }
  }

  // Pre-fill form with selected products from products page
  const productsParam = params.get('products');
  if (productsParam) {
    const products = decodeURIComponent(productsParam).split(',').filter(Boolean);

    if (products.length > 0) {
      const container = document.getElementById('selected-products');
      const tagsEl = document.getElementById('product-tags');
      const inquiryType = document.getElementById('inquiry_type');
      const formSubject = document.getElementById('form-subject');
      const message = document.getElementById('message');

      if (container) container.style.display = 'block';
      products.forEach(name => {
        const tag = document.createElement('span');
        tag.className = 'product-tag';
        tag.textContent = name;
        tagsEl.appendChild(tag);
      });

      if (inquiryType) inquiryType.value = 'Product Inquiry';
      if (formSubject) formSubject.value = `Product Inquiry: ${products.join(', ')}`;
      if (message) message.value = `Hi, I'm interested in the following products: ${products.join(', ')}.\n\nPlease provide more information about pricing and availability.`;
    }
  }
</script>
